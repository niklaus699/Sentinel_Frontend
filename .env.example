# Frontend Environment Variables
# Copy this file to .env and update values for your environment

# API Configuration
# Must be set to the backend API URL. In production, use HTTPS.
# Example: https://api.sentinel.example.com
VITE_API_URL=http://localhost:8000

# WebSocket Configuration
# Must be set to the backend WebSocket URL. In production, use WSS (secure WebSocket).
# Example: wss://api.sentinel.example.com
VITE_WS_URL=ws://localhost:8000

# Optional: Sentry Error Tracking (configure after initial setup)
# VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id
